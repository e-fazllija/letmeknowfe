## Base URL dell'API (lascia "/" in dev: il proxy di Vite inoltra su :3000)
VITE_API_BASE_URL=/

## Prefix API (lascia invariato salvo backend diverso)
VITE_API_PREFIX=/v1

## Tenant pubblico obbligatorio per il widget
## Usato come header x-tenant-id su tutte le rotte public
VITE_PUBLIC_TENANT_ID=cmh4m51hr0002w7jkezailw1h

## Presign allegati abilitato/disabilitato
VITE_PRESIGN_ENABLED=true

## Limiti allegati
VITE_ATTACH_MAX_FILES=3
VITE_ATTACH_MAX_FILE_MB=10
